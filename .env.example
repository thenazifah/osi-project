NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=osi-project-da298
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_SITE_URL=https://organicscales.com

# Meta Pixel (Facebook / Instagram ads) — optional if managed in /admin/site
NEXT_PUBLIC_META_PIXEL_ID=

# Admin dashboard (server-only)
ADMIN_SECRET=change-me-to-a-long-random-string
# Optional comma-separated override (defaults to project allowlist in lib/admin-allowlist.ts)
ADMIN_ALLOWED_EMAILS=nazifahanwar693563@gmail.com,sifatali008@gmail.com
# Easiest: save downloaded JSON as firebase-service-account.json in project root:
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# Or paste full Firebase service account JSON as a single line:
FIREBASE_SERVICE_ACCOUNT_KEY=

# Cloudinary — required for dashboard image upload (https://cloudinary.com/console)
# Cloud name: Dashboard top-left (e.g. dxyz123abc)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_API_KEY=
# Option A: unsigned preset (Settings → Upload → Upload presets → Unsigned)
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
# Option B: signed uploads from dashboard (API Keys → API Secret)
CLOUDINARY_API_SECRET=

# WhatsApp (floating chat button) — country code + number, e.g. 8801712345678
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Optional social profile URLs
NEXT_PUBLIC_SOCIAL_WHATSAPP=
NEXT_PUBLIC_SOCIAL_WECHAT=
NEXT_PUBLIC_SOCIAL_LINE=
NEXT_PUBLIC_SOCIAL_FACEBOOK=
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_TIKTOK=

# Optional Firebase Storage PDF URLs
NEXT_PUBLIC_DOC_TRADE_LICENSE=
NEXT_PUBLIC_DOC_EXPORT_LICENSE=
NEXT_PUBLIC_DOC_IRC=
NEXT_PUBLIC_DOC_ENVIRONMENTAL=
NEXT_PUBLIC_DOC_QUALITY=
